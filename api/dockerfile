# 1. Usa uma imagem super leve do Node.js
FROM node:18-alpine

# 2. Define a pasta de trabalho lá dentro do container
WORKDIR /app

# 3. Copia apenas os arquivos de dependência primeiro (Isso deixa o Docker muito mais rápido)
COPY package*.json ./
COPY prisma ./prisma/

# 4. Instala as dependências
RUN npm install

# 5. Gera o Prisma Client (Passo OBRIGATÓRIO para o Prisma funcionar no Docker)
RUN npx prisma generate

# 6. Agora sim, copia todo o resto do seu código TypeScript
COPY . .

# 7. Compila o TypeScript para JavaScript (gera a pasta /dist ou /build)
RUN npm run build

# 8. Avisa qual porta a API vai usar
EXPOSE 3000

# 9. O comando que liga a API de fato
CMD ["npm", "start"]